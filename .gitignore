# Build outputs
build/
out/
cmake-build-*/

# Native objects/binaries (default)
*.obj
*.o
*.pdb
*.ilk
*.idb
*.exe
*.dll
*.so
*.dylib
*.a
*.lib

# Future release policy:
# Allow committed SDK binaries only under /bin and /lib when intentionally published.
!bin/
!lib/
!bin/**/*.dll
!bin/**/*.so
!bin/**/*.dylib
!bin/**/*.exe
!lib/**/*.lib
!lib/**/*.a
!lib/**/*.dll
!lib/**/*.so
!lib/**/*.dylib

# CMake/Ninja artifacts
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
build.ninja
.ninja_deps
.ninja_log

# Python
__pycache__/
*.pyc

# .NET
bin/obj/
*.nupkg

# OS/editor
.vs/
.vscode/
.DS_Store
Thumbs.db

# Non-SDK content (marketing, drafts, personal)
linkedin_article_*.md
# Internal verification artifacts (keep local, not part of public surface)
reports/*
# EXCEPTION (scoped, do NOT wholesale un-ignore reports/): published determinism evidence IS
# committed — committed-but-not-shipped (still excluded from the MANIFEST surface). Mandated by
# determinism_evidence_bundle_v1_0.md §1 (evidence lives under reports/determinism_v1_0/) and
# published_evidence_index_v1_0.md §2 (published evidence is a committed bundle directory).
!reports/determinism_v1_0/
!reports/determinism_compare_v1/

# Keep fixture placeholder binaries tracked for public bundle audit in CI.
!Tools/release_bundle/fixtures/min_bundle/bin/
!Tools/release_bundle/fixtures/min_bundle/bin/*.exe
!Tools/release_bundle/fixtures/min_bundle/bin/*.dll


# Generated delivery bundle (produced by Tools/release_bundle/build_bundle.ps1 at release; not committed)
/bundle/

# Generated example build artifacts (compiled fresh by CI verify-examples)
examples/*/rules.axbc
examples/*/compile_manifest.json
